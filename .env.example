# Observer — .env.example
# Copy to .env and fill in your API keys.
# Omit or leave blank any key to disable that source.

# --- Enrichment Source API Keys ---

# Shodan — https://account.shodan.io/register (free tier available)
SHODAN_API_KEY=

# VirusTotal — https://www.virustotal.com/gui/join-us (free tier: 500 req/day)
VIRUSTOTAL_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/register (free tier: 1000 checks/day)
ABUSEIPDB_API_KEY=

# AlienVault OTX — https://otx.alienvault.com/ (free, create an account)
OTX_API_KEY=

# ipinfo.io — https://ipinfo.io/signup (free: 50k req/month; token unlocks privacy data)
IPINFO_TOKEN=

# GreyNoise — https://www.greynoise.io/plan/community (free community tier)
GREYNOISE_API_KEY=

# --- Server Configuration ---

# API key required on X-API-Key header for /api/* routes.
# Leave empty to disable auth (development/local use only — log warning on startup).
OBSERVER_API_KEY=

# Port the web server listens on.
OBSERVER_PORT=8080

# Log verbosity: debug, info, warn, error
OBSERVER_LOG_LEVEL=info

# --- Tuning ---

# Per-enricher context timeout in seconds.
ENRICHER_TIMEOUT_SECONDS=15

# Max concurrent goroutines in bulk mode.
BULK_CONCURRENCY=5
